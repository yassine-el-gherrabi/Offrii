# PostgreSQL
POSTGRES_USER=offrii
POSTGRES_PASSWORD=change-me
POSTGRES_DB=offrii

# Database (manual setup only — Docker Compose builds this from vars above)
DATABASE_URL=postgresql://offrii:change-me@localhost:5432/offrii

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-in-production
JWT_ACCESS_EXPIRY=900
JWT_REFRESH_EXPIRY=2592000

# Server
API_HOST=0.0.0.0
API_PORT=3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
