# PostgreSQL
POSTGRES_DB=offrii
POSTGRES_USER=offrii
POSTGRES_PASSWORD=
POSTGRES_PORT=5432
DATABASE_URL=postgres://offrii:YOUR_PASSWORD@localhost:5432/offrii

# Redis
REDIS_PORT=6379
