# PostgreSQL
POSTGRES_DB=offrii
POSTGRES_USER=offrii
POSTGRES_PASSWORD=
POSTGRES_PORT=5432
DATABASE_URL=postgres://offrii:YOUR_PASSWORD@localhost:5432/offrii

# Redis
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# API
API_PORT=3000
RUST_LOG=rest_api=debug,tower_http=debug

# JWT (RS256 — clés asymétriques)
JWT_PRIVATE_KEY_FILE=
JWT_PUBLIC_KEY_FILE=

# Caddy
CADDY_SITE_ADDRESS=http://:80
# Production : CADDY_SITE_ADDRESS=api.offrii.com
