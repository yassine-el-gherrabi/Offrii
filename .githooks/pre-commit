#!/usr/bin/env bash
set -e

check_tool() {
    if ! command -v "$1" &> /dev/null; then
        echo "Warning: $1 not found, skipping. Install with: cargo install $1"
        return 1
    fi
}

# Backend checks (only if backend files are staged)
if git diff --cached --name-only | grep -q '^backend/'; then
    echo "==> Backend pre-commit checks"
    (
        cd backend
        echo "  cargo fmt --check"
        cargo fmt --all -- --check
        if check_tool cargo-sort; then
            echo "  cargo sort --check"
            cargo sort --workspace --check
        fi
        echo "  cargo clippy"
        cargo clippy --workspace --all-targets -- -D warnings
    )
    echo "==> Backend checks passed"
fi

# iOS frontend checks (only if frontend/ios files are staged)
if git diff --cached --name-only | grep -q '^frontend/ios/'; then
    echo "==> iOS frontend pre-commit checks"
    (
        cd frontend/ios
        if command -v swiftlint &> /dev/null; then
            echo "  swiftlint"
            swiftlint lint --quiet --config .swiftlint.yml
        else
            echo "  swiftlint not found, skipping"
        fi
    )
    echo "==> iOS frontend checks passed"
fi
